{
  "name": "@stbr/solana-stablecoin-standard",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "cli",
    "sdk",
    "backend",
    "frontend",
    "sss-oracle-frontend",
    "tui"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "npx concurrently \"yarn dev:frontend\" \"yarn dev:backend\"",
    "build": "yarn workspaces foreach -A run build",
    "build:frontend": "yarn workspace frontend run build",
    "build:backend": "yarn workspace backend run build",
    "build:sdk": "yarn workspace @stbr/sss-token run build",
    "build:oracle-frontend": "yarn workspace sss-oracle-frontend run build",
    "build:cli": "yarn workspace @stbr/sss-cli run build",
    "dev:frontend": "yarn workspace frontend run dev",
    "dev:backend": "yarn workspace backend run start:dev",
    "clean": "yarn workspaces foreach -A run clean",
    "test": "anchor test",
    "test:local": "anchor test --skip-local-validator",
    "test:fuzz": "cd trident-tests && trident fuzz run fuzz_0 && trident fuzz run fuzz_1 && trident fuzz run fuzz_2",
    "test:fuzz:0": "cd trident-tests && trident fuzz run fuzz_0",
    "test:fuzz:1": "cd trident-tests && trident fuzz run fuzz_1",
    "test:fuzz:2": "cd trident-tests && trident fuzz run fuzz_2",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
  }
}