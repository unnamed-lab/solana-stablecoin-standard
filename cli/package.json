{
    "name": "@stbr/sss-cli",
    "version": "0.1.0",
    "description": "CLI for the Solana Stablecoin Standard (SSS)",
    "main": "dist/index.js",
    "bin": {
        "sss-token": "./dist/index.js"
    },
    "license": "MIT",
    "preferGlobal": true,
    "engines": {
        "node": ">=18"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsx src/index.ts",
        "clean": "rm -rf dist",
        "link": "npm run build && npm link",
        "test": "mocha -r ts-node/register src/**/*.test.ts",
        "test:watch": "mocha -w -r ts-node/register src/**/*.test.ts",
        "test:coverage": "echo 'Coverage not available for mocha'"
    },
    "dependencies": {
        "@clack/prompts": "^1.1.0",
        "@solana/web3.js": "^1.95.3",
        "@stbr/sss-token": "file:../sdk",
        "chalk": "^4.1.2",
        "commander": "^12.1.0",
        "ora": "^5.4.1",
        "toml": "^3.0.0"
    },
    "devDependencies": {
        "@types/node": "^22.5.4",
        "@types/proxyquire": "^1.3.31",
        "@types/sinon": "^21.0.0",
        "@vitest/coverage-v8": "^4.0.18",
        "execa": "^9.6.1",
        "proxyquire": "^2.1.3",
        "sinon": "^21.0.2",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.5.4",
        "vitest": "^4.0.18"
    }
}
