# =================================================================
# SSS Backend — Environment Variables
# Copy to .env and fill in values
# =================================================================

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://sss:changeme@localhost:5432/sss_token

# ── Redis (for BullMQ webhook queue) ─────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Solana RPC ───────────────────────────────────────────────────
RPC_URL=https://api.devnet.solana.com
WS_URL=wss://api.devnet.solana.com/
SOLANA_NETWORK=devnet

# ── Program & Token ──────────────────────────────────────────────
SSS_CORE_PROGRAM_ID=AVKfSdE7SLvR4NzK7C8kcSRK4BauKwSoUApZaUC5US9c
ORACLE_PROGRAM_ID=CUKfNWS1uWT29GccLKtGMoRB1sqascAjH7GoEddHSfEi
MINT_ADDRESS=

# ── API ──────────────────────────────────────────────────────────
PORT=4000
ORACLE_PORT=4001
NODE_ENV=development

# ── Docker (used only in docker-compose) ─────────────────────────
DB_PASSWORD=changeme

# ── CORS ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173